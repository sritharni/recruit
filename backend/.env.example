# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=recruit

# OpenAI (required for resume parsing)
OPENAI_API_KEY=your_openai_api_key_here

# Skills similarity search (cosine distance threshold, lower = stricter)
SKILLS_SIMILARITY_THRESHOLD=0.7

# Vercel Blob (required for resume uploads on Vercel)
BLOB_READ_WRITE_TOKEN=
